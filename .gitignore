# ── macOS ─────────────────────────────────────────────────────────────────────
.DS_Store
.DS_Store?
._*
.Spotlight-V100
.Trashes

# ── Windows ───────────────────────────────────────────────────────────────────
Thumbs.db
ehthumbs.db
Desktop.ini
$RECYCLE.BIN/

# ── Credentials & Secrets (NEVER commit these) ────────────────────────────────
*.xml           # Export-Clixml credential files
vault_pass.txt  # Ansible vault password files
vault_pass      # Ansible vault password files (no extension)
.vault_pass*
*password*
*credentials*
*.creds
.env
*.pem
*.key
*.pfx
*.p12
id_rsa
id_ed25519
*.pub

# ── PowerShell Script Output ──────────────────────────────────────────────────
*.log
*.csv           # Script output CSVs (generated at runtime)
*-report-*.csv
*-report-*.html
*DryRun*.csv

# ── Ansible ───────────────────────────────────────────────────────────────────
*.retry         # Ansible retry files
__pycache__/
*.pyc
*.pyo
.ansible/
ansible_facts/

# ── Python ────────────────────────────────────────────────────────────────────
*.egg-info/
dist/
build/
venv/
.venv/
env/
*.egg

# ── Node / vLab ───────────────────────────────────────────────────────────────
node_modules/
npm-debug.log*
.npm

# ── Editor & IDE ──────────────────────────────────────────────────────────────
.vscode/settings.json
.idea/
*.swp
*.swo
*~

# ── Temp / Working Files ──────────────────────────────────────────────────────
*.tmp
*.bak
*.old
*.orig
~$*
.claude/settings.local.json
